# ══════════════════════════════════════════════════════════
# 백엔드 환경변수 — Railway 배포 기준
# ══════════════════════════════════════════════════════════

# ── 기본 ─────────────────────────────────────────────────
DATABASE_URL=sqlite:///./soccer_analyzer.db
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# ── 파일 업로드 ───────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=2048

# ── RunPod GPU 분석 (자동 켜고 끄기) ──────────────────────
# RunPod 가입 후 발급: https://runpod.io/console/user/settings
RUNPOD_API_KEY=your_runpod_api_key_here
RUNPOD_ENDPOINT_ID=your_endpoint_id_here

# ── Supabase Storage (영상 영구 저장) ──────────────────────
# Supabase 프로젝트 생성 후 발급: https://supabase.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here
SUPABASE_BUCKET=soccer-videos

# ── Cloudflare R2 Storage (영상 직접 업로드, 크기 제한 없음) ──────────────
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
R2_BUCKET=soccer-videos
R2_PUBLIC_URL=https://pub-xxxx.r2.dev
