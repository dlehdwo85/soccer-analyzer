# ══════════════════════════════════════════════════════════
# 백엔드 환경변수 — Railway 배포 기준
# ══════════════════════════════════════════════════════════
#
# 사용법:
#   로컬: 이 파일을 .env로 복사 후 값 수정
#   Railway: 대시보드 > Variables 탭에서 직접 입력
# ══════════════════════════════════════════════════════════

# ── 데이터베이스 ─────────────────────────────────────────
# Railway에서 PostgreSQL 플러그인 추가 시 자동으로 설정됨
# 로컬에서는 아래 SQLite 기본값 사용 (변경 불필요)
DATABASE_URL=sqlite:///./soccer_analyzer.db

# ── CORS: 허용할 프론트엔드 주소 ─────────────────────────
# Vercel 배포 후 실제 주소로 교체
# 여러 개면 쉼표로 구분
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# ── 업로드 설정 ───────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=2048

# ── 분석 설정 ────────────────────────────────────────────
# 영상 샘플링 주기 (값이 클수록 빠르지만 정확도 하락)
FRAME_SAMPLE_RATE=6
